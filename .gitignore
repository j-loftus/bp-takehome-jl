contracts/

# Generated pipeline artifacts — ignore everything in data/ except the two
# files the deployed app needs and that Task 2.7 commits on purpose:
# data/contracts.db (Task 2.5 structured DB) and data/parse_cache.json
# (Task 2.7 §8.1 — lets the vector store rebuild at startup without shipping PDFs).
data/*
!data/contracts.db
!data/parse_cache.json

# Eval — generated source-text dumps for labeling (operator aid, not a deliverable)
eval/labeling/

